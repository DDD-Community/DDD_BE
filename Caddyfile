admin.dddstudy.kr {
    # 백엔드: API + Swagger (먼저 매칭, 종료)
    handle /api/* {
        reverse_proxy app:3000
    }

    # 프론트엔드: 나머지 모든 경로 (SPA fallback)
    handle {
        root * /srv/frontend/current
        # SPA 라우팅, 새로고침 시 404 안나게하기위해
        try_files {path} /index.html
        # 정적 파일 서빙 핸들러를 활성화
        file_server
    }
}
